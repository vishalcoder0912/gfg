# Backend environment variables
#
# Copy to `backend/.env` and fill values.

# SQLite path (relative to backend/ when running).
APP_DB_PATH=./data/app_data.db

# Maximum allowed CSV upload size in bytes (default: 50MB)
APP_MAX_UPLOAD_BYTES=52428800

# CORS (comma-separated). Next.js dev default is 3000, but dev servers may use 3001 if 3000 is taken.
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Gemini (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Gemini request timeout (seconds). Helps avoid long hangs if the API is unreachable.
GEMINI_TIMEOUT_SECONDS=15
