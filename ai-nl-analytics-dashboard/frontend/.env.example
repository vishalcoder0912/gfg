# Frontend environment variables
#
# Copy to `.env.local` for development.

# URL of the backend API.
# Recommended for local dev: keep frontend and backend same-origin via Next rewrites (/api -> backend).
NEXT_PUBLIC_API_URL=/api

# Backend URL used by Next.js rewrites (server-side). Not exposed to the browser.
API_URL=http://localhost:8000

# Optional: frontend-side CSV upload size cap (bytes). Should match backend APP_MAX_UPLOAD_BYTES.
NEXT_PUBLIC_MAX_UPLOAD_BYTES=52428800
